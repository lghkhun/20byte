# Production-friendly Docker Compose env baseline.
# Copy to `.env` on the VPS, then adjust values before first boot.

APP_PORT=3000
MYSQL_PORT=3307
REDIS_PORT=6379
WEB_BLUE_PORT=3100
WEB_GREEN_PORT=3200

MYSQL_IMAGE=mysql:8
MYSQL_ROOT_PASSWORD=replace-with-strong-root-password
MYSQL_DATABASE=20byte
MYSQL_USER=app
MYSQL_PASSWORD=replace-with-strong-app-password

REDIS_IMAGE=redis:7-alpine

NEXTAUTH_SECRET=replace-with-long-random-secret
NEXTAUTH_URL=https://app.example.com
APP_URL=https://app.example.com
SHORTLINK_BASE_URL=https://app.example.com/r

WHATSAPP_MOCK_MODE=false

RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_REPLY_TO_EMAIL=

PAKASIR_PROJECT_SLUG=
PAKASIR_API_KEY=
PAKASIR_BASE_URL=https://app.pakasir.com
PAKASIR_DEFAULT_METHOD=qris
PAKASIR_WEBHOOK_PATH=/api/billing/webhooks/pakasir
PAKASIR_WEBHOOK_TOKEN=

SUPERADMIN_EMAILS=owner@example.com

ABLY_API_KEY=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
