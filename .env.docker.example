# Docker app profile baseline (`docker compose --profile app up -d`)
# Copy to `.env` and adjust for your environment.

MYSQL_PORT=3307
REDIS_PORT=6379
MYSQL_IMAGE=mysql:8
REDIS_IMAGE=redis:7

NEXTAUTH_SECRET=dev-nextauth-secret
NEXTAUTH_URL=http://localhost:3000
APP_URL=http://localhost:3000
SHORTLINK_BASE_URL=http://localhost:3000/r

WHATSAPP_WEBHOOK_VERIFY_TOKEN=dev-whatsapp-webhook-verify-token
WHATSAPP_APP_SECRET=dev-whatsapp-app-secret
WHATSAPP_TOKEN_ENCRYPTION_KEY=dev-whatsapp-token-encryption-key
WHATSAPP_EMBEDDED_APP_ID=dev-whatsapp-embedded-app-id
WHATSAPP_EMBEDDED_CONFIG_ID=dev-whatsapp-embedded-config-id
WHATSAPP_MOCK_MODE=true

# Optional placeholders for direct token mode
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

ABLY_API_KEY=ably-key-placeholder
R2_ACCOUNT_ID=r2-account-id
R2_ACCESS_KEY_ID=r2-access-key
R2_SECRET_ACCESS_KEY=r2-secret-key
R2_BUCKET=20byte-media
R2_PUBLIC_URL=https://example-r2-public-url.invalid
