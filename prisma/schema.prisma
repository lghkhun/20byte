generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  CS
  ADVERTISER
}

enum ConversationStatus {
  OPEN
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  TEMPLATE
  SYSTEM
}

enum MessageSendStatus {
  PENDING
  SENT
  FAILED
}

enum MessageDeliveryStatus {
  SENT
  DELIVERED
  READ
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  VOID
}

enum InvoiceKind {
  FULL
  DP_AND_FINAL
}

enum PaymentMilestoneType {
  FULL
  DP
  FINAL
}

enum ProofType {
  TRANSFER
}

enum WaTemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
  SERVICE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum BillingChargeStatus {
  PENDING
  PAID
  EXPIRED
  CANCELED
  FAILED
}

enum InvoiceGatewayFeePolicy {
  MERCHANT
  CUSTOMER
}

enum InvoicePaymentAttemptStatus {
  PENDING
  PAID
  EXPIRED
  CANCELED
  FAILED
  SUPERSEDED
}

enum WalletLedgerType {
  TOPUP_CREDIT
  WITHDRAW_DEBIT
  WITHDRAW_REFUND
  INVOICE_FEE_DEBIT
}

enum WalletLedgerDirection {
  CREDIT
  DEBIT
}

enum WalletTopupStatus {
  PENDING
  PAID
  EXPIRED
  CANCELED
  FAILED
}

enum WalletWithdrawStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
  CANCELED
}

enum WhatsAppPublicScheduleStatus {
  PENDING
  SENT
  FAILED
  CANCELED
}

enum AccountSetupTokenPurpose {
  SET_PASSWORD
}

enum PlatformRole {
  SUPERADMIN
}

model Org {
  id                 String   @id @default(cuid())
  name               String
  legalName          String?
  responsibleName    String?
  businessPhone      String?
  businessEmail      String?
  businessNpwp       String?
  businessAddress    String?  @db.Text
  logoUrl            String?
  invoiceSignatureUrl String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Future wallet placeholder (Phase 2+), keep for forward compatibility
  walletBalanceCents Int      @default(0)

  members            OrgMember[]
  customers          Customer[]
  customerTags       CustomerTag[]
  customerNotes      CustomerNote[]
  conversations      Conversation[]
  messages           Message[]
  invoices           Invoice[]
  invoiceItems       InvoiceItem[]
  paymentMilestones  PaymentMilestone[]
  paymentProofs      PaymentProof[]
  invoiceSequences   InvoiceSequence[]
  tags               Tag[]
  serviceCatalogItems ServiceCatalogItem[]
  waAccounts         WaAccount[]
  shortlinks         Shortlink[]
  shortlinkClicks    ShortlinkClick[]
  metaIntegrations   MetaIntegration[]
  metaEventDispatches MetaEventDispatch[]
  auditLogs          AuditLog[]
  setupTokens        AccountSetupToken[]
  subscription       OrgSubscription?
  billingCharges     BillingCharge[]
  plan               OrgPlan?
  bankAccounts       OrgBankAccount[]
  crmPipelines       CrmPipeline[]
  crmPipelineStages  CrmPipelineStage[]
  invoicePaymentSetting OrgInvoicePaymentSetting?
  invoicePaymentAttempts InvoicePaymentAttempt[]
  walletTopups       OrgWalletTopup[]
  walletLedgers      OrgWalletLedger[]
  walletWithdrawRequests OrgWalletWithdrawRequest[]
  provisioningOrders OwnerBusinessProvisioningOrder[]
  whatsappApiKey     OrgWhatsAppApiKey?
  whatsappPublicWebhook OrgWhatsAppPublicWebhook?
  whatsappPublicSchedules OrgWhatsAppPublicSchedule[]
  whatsappPublicWebhookEvents OrgWhatsAppPublicWebhookEvent[]

  @@index([createdAt])
}

model OrgPlan {
  id             String   @id @default(cuid())
  orgId          String   @unique
  planKey        String   // starter | growth | pro
  seatLimit      Int
  storageQuotaMb Int
  retentionDays  Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  org            Org      @relation(fields: [orgId], references: [id])
}

model OrgMember {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  role      Role
  createdAt DateTime @default(now())

  org       Org      @relation(fields: [orgId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  assignedConversations Conversation[] @relation("AssignedConversations")

  @@unique([orgId, userId])
  @@index([orgId, role])
}

model User {
  id                        String              @id @default(cuid())
  email                     String              @unique
  phoneE164                 String?             @unique
  passwordHash              String?
  passwordSetAt             DateTime?
  securityNoticeDismissedAt DateTime?
  isSuspended               Boolean             @default(false)
  name                      String?
  avatarUrl                 String?
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt

  memberships               OrgMember[]
  setupTokens               AccountSetupToken[]
  platformMembership        PlatformMember?
  provisioningOrders        OwnerBusinessProvisioningOrder[]
  createdWhatsAppApiKeys    OrgWhatsAppApiKey[]
  createdWhatsAppPublicSchedules OrgWhatsAppPublicSchedule[]

  @@index([phoneE164])
}

model OrgBankAccount {
  id            String   @id @default(cuid())
  orgId         String
  bankName      String
  accountNumber String
  accountHolder String
  createdAt     DateTime @default(now())

  org           Org      @relation(fields: [orgId], references: [id])

  @@index([orgId])
}

model WaAccount {
  id             String   @id @default(cuid())
  orgId          String
  metaBusinessId String
  wabaId         String
  phoneNumberId  String
  displayPhone   String
  createdAt      DateTime @default(now())
  connectedAt    DateTime @default(now())

  // Store encrypted token only
  accessTokenEnc String

  org            Org      @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@unique([orgId])
  @@unique([orgId, phoneNumberId])
  @@unique([phoneNumberId])
}

model Customer {
  id              String   @id @default(cuid())
  orgId           String
  phoneE164       String
  displayName     String?
  waProfilePicUrl String?
  leadStatus      String   @default("NEW_LEAD")
  followUpStatus  String?
  followUpAt      DateTime?
  businessCategory String?
  detail          String?
  hotness         String   @default("COLD")
  packageName     String?
  projectValueCents Int?
  remarks         String?  @db.Text
  assignedToMemberId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Attribution (persisted on customer)
  source          String?  // organic | meta_ads | etc
  campaign        String?
  adset           String?
  ad              String?
  platform        String?
  medium          String?
  firstContactAt  DateTime?

  org             Org      @relation(fields: [orgId], references: [id])
  conversations   Conversation[]
  invoices        Invoice[]
  notes           CustomerNote[]
  tagLinks        CustomerTag[]

  @@unique([orgId, phoneE164])
  @@index([orgId])
  @@index([orgId, createdAt])
  @@index([orgId, updatedAt])
  @@index([orgId, displayName])
  @@index([orgId, leadStatus, firstContactAt])
  @@index([orgId, hotness, firstContactAt])
  @@index([orgId, assignedToMemberId, firstContactAt])
  @@index([orgId, source, firstContactAt])
  @@index([orgId, followUpAt])
  @@index([orgId, firstContactAt, createdAt], map: "cust_org_firstcontact_created_idx")
}

model Tag {
  id           String      @id @default(cuid())
  orgId        String
  name         String
  color        String      // e.g. "emerald", "purple", "amber"
  createdAt    DateTime    @default(now())

  org          Org         @relation(fields: [orgId], references: [id])
  customerLinks CustomerTag[]

  @@unique([orgId, name])
  @@index([orgId])
}

model CustomerTag {
  id         String   @id @default(cuid())
  orgId      String
  customerId String
  tagId      String
  createdAt  DateTime @default(now())

  org        Org      @relation(fields: [orgId], references: [id])
  customer   Customer @relation(fields: [customerId], references: [id])
  tag        Tag      @relation(fields: [tagId], references: [id])

  @@unique([customerId, tagId])
  @@index([orgId])
  @@index([customerId])
}

model CustomerNote {
  id           String   @id @default(cuid())
  orgId        String
  customerId   String
  authorUserId String
  content      String
  createdAt    DateTime @default(now())

  org          Org      @relation(fields: [orgId], references: [id])
  customer     Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, createdAt])
  @@index([orgId, createdAt])
}

model Conversation {
  id                 String             @id @default(cuid())
  orgId              String
  customerId         String
  status             ConversationStatus @default(OPEN)

  assignedToMemberId String? // OrgMember.id
  assignedToMember   OrgMember?         @relation("AssignedConversations", fields: [assignedToMemberId], references: [id])
  lastMessageSenderName String?
  lastMessageAt      DateTime?
  unreadCount        Int                @default(0)

  // Attribution (copied for conversation-level analytics)
  sourceCampaign     String?
  sourcePlatform     String?
  sourceMedium       String?
  shortlinkId        String?
  trackingId         String?
  fbclid             String?
  fbc                String?
  fbp                String?
  ctwaClid           String?
  wabaId             String?
  waChatJid          String?
  groupParticipantsJson String?      @db.LongText
  crmPipelineId      String?
  crmStageId         String?

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  org                Org                @relation(fields: [orgId], references: [id])
  customer           Customer           @relation(fields: [customerId], references: [id])
  crmPipeline        CrmPipeline?       @relation(fields: [crmPipelineId], references: [id])
  crmStage           CrmPipelineStage?  @relation(fields: [crmStageId], references: [id])
  messages           Message[]
  invoices           Invoice[]

  @@index([orgId, status, lastMessageAt])
  @@index([orgId, status, lastMessageAt, updatedAt], map: "conv_org_status_lastmsg_upd_idx")
  @@index([orgId, status, crmPipelineId, lastMessageAt, updatedAt], map: "conv_org_status_pipe_last_upd_idx")
  @@index([orgId, assignedToMemberId, lastMessageAt])
  @@index([orgId, assignedToMemberId, status, lastMessageAt, updatedAt], map: "conv_org_assignee_status_lastmsg_upd_idx")
  @@index([orgId, assignedToMemberId, status, crmPipelineId, lastMessageAt, updatedAt], map: "conv_org_asg_st_pipe_last_upd_idx")
  @@index([customerId])
  @@index([orgId, waChatJid], map: "conv_org_wa_chat_jid_idx")
  @@index([trackingId])
  @@index([ctwaClid])
  @@index([crmPipelineId])
  @@index([crmStageId])
}

model CrmPipeline {
  id          String             @id @default(cuid())
  orgId       String
  name        String
  isDefault   Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  org         Org                @relation(fields: [orgId], references: [id])
  stages      CrmPipelineStage[]
  conversations Conversation[]

  @@index([orgId, createdAt])
  @@unique([orgId, name])
}

model CrmPipelineStage {
  id            String          @id @default(cuid())
  orgId         String
  pipelineId    String
  name          String
  color         String          @default("emerald")
  position      Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  org           Org             @relation(fields: [orgId], references: [id])
  pipeline      CrmPipeline     @relation(fields: [pipelineId], references: [id])
  conversations Conversation[]

  @@index([orgId, pipelineId, position])
  @@unique([pipelineId, name])
}

model Message {
  id               String             @id @default(cuid())
  orgId            String
  conversationId   String
  waMessageId      String?            @unique

  direction        MessageDirection
  type             MessageType
  text             String?            @db.LongText

  // Media metadata
  mediaId          String?            // WhatsApp media ID (for retrieval)
  mediaUrl         String?            // R2 public or signed URL
  mimeType         String?
  fileName         String?
  fileSize         Int?
  durationSec      Int?

  // Template metadata
  templateName     String?
  templateCategory WaTemplateCategory?
  templateLanguageCode String?
  templateComponentsJson String?

  // System metadata
  isAutomated      Boolean            @default(false)
  sendStatus       MessageSendStatus?
  deliveryStatus   MessageDeliveryStatus?
  sendError        String?
  sendAttemptCount Int                @default(0)
  lastSendAttemptAt DateTime?
  deliveredAt      DateTime?
  readAt           DateTime?
  retryable        Boolean            @default(false)

  // Reply metadata (WhatsApp quoted message context)
  replyToMessageId   String?
  replyToWaMessageId String?
  replyPreviewText   String?
  replyPreviewSenderName String?

  // Sender metadata (important for group chats)
  senderWaJid        String?
  senderPhoneE164    String?
  senderDisplayName  String?

  createdAt        DateTime           @default(now())

  org              Org                @relation(fields: [orgId], references: [id])
  conversation     Conversation       @relation(fields: [conversationId], references: [id])
  paymentProofs    PaymentProof[]

  @@index([conversationId, createdAt])
  @@index([orgId, conversationId, createdAt], map: "msg_org_conv_created_idx")
  @@index([orgId, createdAt])
  @@index([orgId, conversationId, replyToMessageId, createdAt], map: "msg_org_conv_reply_created_idx")
}

model ServiceCatalogItem {
  id             String   @id @default(cuid())
  orgId          String
  name           String
  category       String?
  unit           String?
  priceCents     Int?
  currency       String   @default("IDR")

  // Allowed attachments: image/pdf/link (no video)
  attachmentUrl  String?
  attachmentType String?  // "image" | "pdf" | "link"

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  org            Org      @relation(fields: [orgId], references: [id])

  @@index([orgId, createdAt])
}

model Invoice {
  id               String        @id @default(cuid())
  orgId            String
  customerId       String
  conversationId   String?
  customerDisplayNameSnapshot String?

  invoiceNo        String
  kind             InvoiceKind
  status           InvoiceStatus @default(DRAFT)

  currency         String        @default("IDR")
  grossSubtotalCents Int         @default(0)
  lineDiscountCents Int          @default(0)
  invoiceDiscountType String     @default("%")
  invoiceDiscountValue Int       @default(0)
  invoiceDiscountCents Int       @default(0)
  taxCents         Int           @default(0)
  subtotalCents    Int           @default(0)
  totalCents       Int           @default(0)

  // Optional due date (per invoice overall)
  dueDate          DateTime?

  // Public access token
  publicToken      String        @unique

  // Snapshot of bank accounts for invoice rendering (stable even if org settings change later)
  bankAccountsJson String        @db.LongText

  // PDF stored on R2
  pdfUrl           String?
  notes            String?       @db.LongText
  terms            String?       @db.LongText

  createdByUserId  String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  org              Org           @relation(fields: [orgId], references: [id])
  customer         Customer      @relation(fields: [customerId], references: [id])
  conversation     Conversation? @relation(fields: [conversationId], references: [id])

  items            InvoiceItem[]
  milestones       PaymentMilestone[]
  proofs           PaymentProof[]
  paymentAttempts  InvoicePaymentAttempt[]

  @@index([orgId, customerId, createdAt])
  @@index([conversationId])
  @@index([orgId, conversationId, createdAt], map: "inv_org_conv_created_idx")
  @@unique([orgId, invoiceNo])
}

model OrgInvoicePaymentSetting {
  id               String                  @id @default(cuid())
  orgId            String                  @unique
  enableBankTransfer Boolean               @default(true)
  enableQris       Boolean                 @default(false)
  enabledVaMethodsJson String              @db.LongText
  feePolicy        InvoiceGatewayFeePolicy @default(CUSTOMER)
  autoConfirmLabelEnabled Boolean          @default(true)
  paymentMethodsOrderJson String?          @db.LongText
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  org              Org                     @relation(fields: [orgId], references: [id])
}

model InvoicePaymentAttempt {
  id                 String                      @id @default(cuid())
  orgId              String
  invoiceId          String
  orderId            String                      @unique
  provider           String                      @default("pakasir")
  paymentMethod      String
  feePolicy          InvoiceGatewayFeePolicy
  invoiceAmountCents Int
  feeCents           Int                         @default(0)
  customerPayableCents Int
  status             InvoicePaymentAttemptStatus @default(PENDING)
  paymentNumber      String?                     @db.LongText
  expiresAt          DateTime?
  paidAt             DateTime?
  gatewayRawJson     String?                     @db.LongText
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  org                Org                         @relation(fields: [orgId], references: [id])
  invoice            Invoice                     @relation(fields: [invoiceId], references: [id])

  @@index([orgId, invoiceId, createdAt])
  @@index([orgId, status, createdAt])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  orgId       String
  invoiceId   String
  name        String
  description String?
  qty         Int      @default(1)
  unit        String?
  priceCents  Int
  subtotalCents Int    @default(0)
  discountType String  @default("IDR")
  discountValue Int    @default(0)
  discountCents Int    @default(0)
  taxLabel    String?
  taxRateBps  Int      @default(0)
  taxCents    Int      @default(0)
  amountCents Int
  createdAt   DateTime @default(now())

  org         Org      @relation(fields: [orgId], references: [id])
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])

  @@index([orgId, invoiceId])
  @@index([invoiceId])
}

model PaymentMilestone {
  id          String               @id @default(cuid())
  orgId       String
  invoiceId   String
  type        PaymentMilestoneType
  amountCents Int
  dueDate     DateTime?
  status      String               // "PENDING" | "PAID"
  paidAt      DateTime?
  createdAt   DateTime             @default(now())

  org         Org                  @relation(fields: [orgId], references: [id])
  invoice     Invoice              @relation(fields: [invoiceId], references: [id])

  @@index([orgId, invoiceId])
  @@index([orgId, status, paidAt], map: "pm_org_status_paidat_idx")
  @@unique([invoiceId, type])
  @@index([invoiceId])
}

model PaymentProof {
  id             String               @id @default(cuid())
  orgId          String
  invoiceId      String
  milestoneType  PaymentMilestoneType? // optional: proof can attach to specific milestone
  type           ProofType            @default(TRANSFER)

  // Link to original chat message (recommended)
  messageId      String?
  mediaUrl       String
  mimeType       String?
  fileSize       Int?

  createdByUserId String
  createdAt      DateTime             @default(now())

  org            Org                  @relation(fields: [orgId], references: [id])
  invoice        Invoice              @relation(fields: [invoiceId], references: [id])
  message        Message?             @relation(fields: [messageId], references: [id])

  @@index([invoiceId, createdAt])
  @@index([orgId, createdAt])
  @@index([messageId])
}

model InvoiceSequence {
  id         String   @id @default(cuid())
  orgId      String
  year       Int
  lastSeq    Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org        Org      @relation(fields: [orgId], references: [id])

  @@unique([orgId, year])
  @@index([orgId, year])
}

model Shortlink {
  id             String   @id @default(cuid())
  orgId          String
  code           String   @unique

  destinationUrl String   // e.g. https://wa.me/...
  source         String   @default("meta_ads")
  campaign       String?
  adset          String?
  adName         String?
  platform       String?
  medium         String?
  isEnabled      Boolean  @default(true)
  disabledAt     DateTime?

  createdAt      DateTime @default(now())

  org            Org      @relation(fields: [orgId], references: [id])
  clicks         ShortlinkClick[]

  @@index([orgId, createdAt])
}

model ShortlinkClick {
  id          String    @id @default(cuid())
  orgId       String
  shortlinkId String
  trackingId  String?
  fbclid      String?
  fbc         String?
  fbp         String?

  createdAt   DateTime  @default(now())
  clickedAt   DateTime  @default(now())
  ipHash      String?   // optional hashed ip
  userAgent   String?   // optional

  org         Org       @relation(fields: [orgId], references: [id])
  shortlink   Shortlink @relation(fields: [shortlinkId], references: [id])

  @@index([shortlinkId, clickedAt])
  @@index([orgId, clickedAt])
  @@index([trackingId])
  @@index([fbclid])
}

model MetaIntegration {
  id             String   @id @default(cuid())
  orgId          String
  pixelId        String
  datasetId      String?
  accessTokenEnc String   @db.Text
  testEventCode  String?
  isEnabled      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  org            Org      @relation(fields: [orgId], references: [id])

  @@unique([orgId])
  @@index([orgId])
}

model MetaEventDispatch {
  id         String   @id @default(cuid())
  orgId      String
  dedupeKey  String
  kind       String
  attempts   Int      @default(0)
  sentAt     DateTime?
  lastError  String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org        Org      @relation(fields: [orgId], references: [id])

  @@unique([orgId, dedupeKey])
  @@index([orgId, sentAt, updatedAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  orgId       String
  actorUserId String?
  action      String
  entityType  String
  entityId    String
  metaJson    String
  createdAt   DateTime @default(now())

  org         Org      @relation(fields: [orgId], references: [id])

  @@index([orgId, createdAt])
  @@index([orgId, entityType, action, entityId, createdAt], map: "alog_org_etype_act_eid_created_idx")
}

model AccountSetupToken {
  id              String                   @id @default(cuid())
  userId          String
  orgId           String
  tokenHash       String                   @unique @db.Char(64)
  purpose         AccountSetupTokenPurpose @default(SET_PASSWORD)
  expiresAt       DateTime
  usedAt          DateTime?
  createdByUserId String?
  createdAt       DateTime                 @default(now())

  user            User                     @relation(fields: [userId], references: [id])
  org             Org                      @relation(fields: [orgId], references: [id])

  @@index([orgId, userId, purpose])
  @@index([expiresAt])
}

model OrgSubscription {
  id                   String             @id @default(cuid())
  orgId                String             @unique
  status               SubscriptionStatus @default(TRIALING)
  trialStartAt         DateTime
  trialEndAt           DateTime
  graceDays            Int                @default(3)
  currentPeriodStartAt DateTime?
  currentPeriodEndAt   DateTime?
  nextDueAt            DateTime?
  baseAmountCents      Int                @default(99000)
  gatewayFeeBps        Int                @default(200)
  currency             String             @default("IDR")
  lastPaidAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  org                  Org                @relation(fields: [orgId], references: [id])
}

model BillingCharge {
  id                String            @id @default(cuid())
  orgId             String
  orderId           String            @unique
  status            BillingChargeStatus @default(PENDING)
  baseAmountCents   Int
  gatewayFeeCents   Int
  totalAmountCents  Int
  paymentMethod     String            @default("qris")
  gatewayProvider   String            @default("pakasir")
  gatewayProjectSlug String
  gatewayRawJson    String?           @db.LongText
  paymentNumber     String?           @db.LongText
  expiredAt         DateTime?
  paidAt            DateTime?
  createdByUserId   String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  org               Org               @relation(fields: [orgId], references: [id])

  @@index([orgId, createdAt])
  @@index([orgId, status, createdAt])
}

model OwnerBusinessProvisioningOrder {
  id                String             @id @default(cuid())
  userId            String
  orderId           String             @unique
  businessName      String
  status            BillingChargeStatus @default(PENDING)
  baseAmountCents   Int
  gatewayFeeCents   Int
  totalAmountCents  Int
  paymentMethod     String             @default("qris")
  gatewayProvider   String             @default("pakasir")
  gatewayProjectSlug String
  gatewayRawJson    String?            @db.LongText
  paymentNumber     String?            @db.LongText
  expiredAt         DateTime?
  paidAt            DateTime?
  createdOrgId      String?            @unique
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user              User               @relation(fields: [userId], references: [id])
  createdOrg        Org?               @relation(fields: [createdOrgId], references: [id])

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model OrgWhatsAppApiKey {
  id                String   @id @default(cuid())
  orgId              String   @unique
  keyPrefix          String
  keyHash            String   @unique @db.Char(64)
  lastFour           String   @db.Char(4)
  createdByUserId    String
  rotatedAt          DateTime?
  revokedAt          DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  org                Org      @relation(fields: [orgId], references: [id])
  createdByUser      User     @relation(fields: [createdByUserId], references: [id])

  @@index([orgId, revokedAt, createdAt])
}

model OrgWhatsAppPublicWebhook {
  id                String   @id @default(cuid())
  orgId              String   @unique
  url                String?
  secretEnc          String?
  enabled            Boolean  @default(false)
  eventFiltersJson   String?  @db.LongText
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  org                Org      @relation(fields: [orgId], references: [id])
}

model OrgWhatsAppPublicSchedule {
  id                String                     @id @default(cuid())
  orgId              String
  createdByUserId    String?
  status             WhatsAppPublicScheduleStatus @default(PENDING)
  targetType         String                     // "contact" | "group"
  target             String
  messageType        String                     // "text" | "media_url"
  text               String?                    @db.LongText
  mediaUrl           String?                    @db.LongText
  mimeType           String?
  fileName           String?
  dueAt              DateTime
  sentAt             DateTime?
  canceledAt         DateTime?
  failedAt           DateTime?
  waMessageId        String?
  failureCode        String?
  failureMessage     String?                    @db.Text
  retryCount         Int                        @default(0)
  nextRetryAt        DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  org                Org                        @relation(fields: [orgId], references: [id])
  createdByUser      User?                      @relation(fields: [createdByUserId], references: [id])

  @@index([orgId, status, dueAt])
  @@index([status, dueAt])
  @@index([createdAt])
}

model OrgWhatsAppPublicWebhookEvent {
  id                String   @id @default(cuid())
  eventId            String   @unique
  orgId              String
  type               String
  payloadJson        String   @db.LongText
  status             String   @default("PENDING")
  attempts           Int      @default(0)
  nextAttemptAt      DateTime?
  deliveredAt        DateTime?
  lastError          String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  org                Org      @relation(fields: [orgId], references: [id])

  @@index([orgId, status, createdAt])
  @@index([status, nextAttemptAt])
}

model OrgWalletTopup {
  id                String           @id @default(cuid())
  orgId             String
  orderId           String           @unique
  amountCents       Int
  feeCents          Int              @default(0)
  customerPayableCents Int
  paymentMethod     String
  paymentNumber     String?          @db.LongText
  status            WalletTopupStatus @default(PENDING)
  expiresAt         DateTime?
  paidAt            DateTime?
  gatewayRawJson    String?          @db.LongText
  createdByUserId   String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  org               Org              @relation(fields: [orgId], references: [id])

  @@index([orgId, status, createdAt])
  @@index([orgId, createdAt])
}

model OrgWalletLedger {
  id                String               @id @default(cuid())
  orgId             String
  type              WalletLedgerType
  direction         WalletLedgerDirection
  amountCents       Int
  balanceAfterCents Int
  referenceType     String
  referenceId       String
  note              String?
  createdByUserId   String?
  createdAt         DateTime             @default(now())

  org               Org                  @relation(fields: [orgId], references: [id])

  @@index([orgId, createdAt])
  @@index([orgId, type, createdAt])
  @@index([referenceType, referenceId])
}

model OrgWalletWithdrawRequest {
  id                String              @id @default(cuid())
  orgId             String
  amountCents       Int
  bankName          String
  accountNumber     String
  accountHolder     String
  status            WalletWithdrawStatus @default(PENDING)
  note              String?             @db.Text
  processedNote     String?             @db.Text
  requestedByUserId String
  processedByUserId String?
  processedAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  org               Org                 @relation(fields: [orgId], references: [id])

  @@index([orgId, status, createdAt])
  @@index([orgId, createdAt])
}

model PlatformMember {
  id              String       @id @default(cuid())
  userId          String       @unique
  role            PlatformRole @default(SUPERADMIN)
  createdByUserId String?
  createdAt       DateTime     @default(now())

  user            User         @relation(fields: [userId], references: [id])
}

model PlatformAuditLog {
  id            String   @id @default(cuid())
  actorUserId   String
  action        String
  targetType    String
  targetId      String
  metaJson      String   @db.LongText
  createdAt     DateTime @default(now())

  @@index([actorUserId, createdAt])
  @@index([targetType, targetId, createdAt])
}
